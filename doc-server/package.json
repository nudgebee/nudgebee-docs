{
  "name": "nudgebee",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start --host 0.0.0.0 --port 4000",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve --host 0.0.0.0",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint . --ext .tsx",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint . --ext .tsx --fix",
    "docs": "HASURA_ADMIN_SECRET=xxx HASURA_GRAPHQL_ENDPOINT=xxx node api-docs/scripts/generate-md-docs.js"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@docusaurus/theme-mermaid": "3.9.2",
    "@easyops-cn/docusaurus-search-local": "^0.55.1",
    "@mdx-js/react": "^3.1.0",
    "axios": "^1.15.2",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@graphql-tools/utils": "^11.0.1",
    "@tsconfig/docusaurus": "^2.0.9",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.59.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "graphql": "^16.13.2",
    "graphql-markdown": "^7.3.0",
    "node-fetch": "^3.3.2",
    "typescript": "^5.8.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "serialize-javascript": "7.0.5"
  }
}
